---
/*
  BaseLayout.astro — the wrapper every page renders inside.

  In Astro, the section between the `---` fences is "frontmatter": JavaScript
  that runs at BUILD time on the server, never in the browser. We use it here
  to declare the props a page can pass in (title, description) and to compute
  the ticker's initial date/time.

  Whatever a page puts inside <BaseLayout>...</BaseLayout> lands where the
  <slot /> is below. The ticker, masthead, and footer live here so all six
  pages share them without repeating the markup.
*/

interface Props {
  title: string;
  description?: string;
  // The blue masthead bar text. Defaults to the site tagline (Home); other
  // pages override it, e.g. the DIY guide passes "Month Offline > DIY Guide".
  masthead?: string;
}

const {
  title,
  description = 'Month Offline — try a dumbphone for 30 days with a cohort of neighbors.',
  masthead = 'Month Offline * Less is MO',
} = Astro.props;

// The masthead doubles as breadcrumb navigation. Crumbs listed here link to
// their page; the current page's own (last) crumb always stays plain text.
const CRUMB_LINKS: Record<string, string> = {
  'Month Offline': '/',
  'DIY Guide': '/diy',
};

// Breadcrumb pages separate crumbs with ">" (e.g. "Month Offline > DIY Guide >
// Participants"). The home page instead uses "*" for its tagline ("Month
// Offline * Less is MO"), which isn't a breadcrumb — handle that case below.
const HOME_CRUMB = 'Month Offline';
const crumbs = masthead.includes('>') ? masthead.split('>').map((c) => c.trim()) : null;
const mastheadRest = masthead.startsWith(HOME_CRUMB) ? masthead.slice(HOME_CRUMB.length) : null;

// Build-time fallback for the ticker, so there's no empty flash before the
// client-side clock kicks in. The inline script below overwrites these with
// the viewer's live local time once the page loads.
const MONTHS = ['JANUARY', 'FEBRUARY', 'MARCH', 'APRIL', 'MAY', 'JUNE', 'JULY', 'AUGUST', 'SEPTEMBER', 'OCTOBER', 'NOVEMBER', 'DECEMBER'];
const now = new Date();
const pad = (n: number) => String(n).padStart(2, '0');
const initialDate = `${MONTHS[now.getMonth()]} ${now.getDate()}, ${now.getFullYear()}`;
const initialTime = `${pad(now.getHours())}:${pad(now.getMinutes())}:${pad(now.getSeconds())}`;

import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Google Fonts: Workbench (display) + Syne Mono (body). preconnect
         speeds up the font fetch. We request the plain Workbench family —
         it serves the full variable font, and we pin the axes in CSS. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Syne+Mono&family=Workbench&display=swap"
    />
  </head>

  <body>
    <!-- Centered column. Everything sits inside this 600px-wide track. -->
    <div class="column">
      <!-- Ticker: live local date + time, on black, scrolling horizontally.
           The content is duplicated into two identical groups; the track
           animates left by 50% (exactly one group's width) and loops
           seamlessly. Both copies carry the .ticker-date/.ticker-time classes
           so the clock script below updates them together. -->
      <div class="ticker font-display">
        <div class="ticker__track">
          <span class="ticker__group">
            <span class="ticker-date">{initialDate}</span> * <span class="ticker-time">{initialTime}</span> * <a class="ticker__link" href="https://www.offline.community">WWW.OFFLINE.COMMUNITY</a> * ALUMNI COUNTER: 400 PPL * CITY COUNTER: 2 * JOIN THE CHALLENGE * DITCH THE DOOMSCROLL * LOG OFF AND LINK UP * TOUCH GRASS *
          </span>
          <span class="ticker__group" aria-hidden="true">
            <span class="ticker-date">{initialDate}</span> * <span class="ticker-time">{initialTime}</span> * <a class="ticker__link" href="https://www.offline.community" tabindex="-1">WWW.OFFLINE.COMMUNITY</a> * ALUMNI COUNTER: 400 PPL * CITY COUNTER: 2 * JOIN THE CHALLENGE * DITCH THE DOOMSCROLL * LOG OFF AND LINK UP * TOUCH GRASS *
          </span>
        </div>
      </div>

      <!-- Masthead bar / breadcrumb. On breadcrumb pages each known crumb links
           to its page (except the current page's own, trailing crumb); on the
           home page only the leading "Month Offline" links home. -->
      <h1 class="masthead">{crumbs ? (
        crumbs.map((crumb, i) => (
          <Fragment>
            {i > 0 && ' > '}
            {CRUMB_LINKS[crumb] && i < crumbs.length - 1
              ? <a class="masthead__link" href={CRUMB_LINKS[crumb]}>{crumb}</a>
              : crumb}
          </Fragment>
        ))
      ) : mastheadRest !== null ? (
        <Fragment><a class="masthead__link" href="/">{HOME_CRUMB}</a>{mastheadRest}</Fragment>
      ) : masthead}</h1>

      <!-- Page content goes here. -->
      <main>
        <slot />
      </main>

      <!-- Footer (centered, on black). -->
      <footer class="site-footer font-display">
        <img class="pinwheel" src="/images/pinwheel.png" alt="" />
        <p><a class="site-footer__link" href="mailto:month@offline.community">MONTH@OFFLINE.COMMUNITY</a></p>
        <p><a class="site-footer__link" href="https://seewunder.studio/" target="_blank" rel="noopener">SEE WHAT'S UNDER STUDIO</a> * <a class="site-footer__link" href="https://dumb.co" target="_blank" rel="noopener">DUMB.CO</a></p>
        <p>DESIGNED WITH CARE IN WASHINGTON, DC</p>
        <p class="site-footer__cc">
          <!-- Creative Commons logo — two C shapes inside a circle -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="16" height="16" aria-hidden="true">
            <circle cx="50" cy="50" r="47" fill="none" stroke="currentColor" stroke-width="6"/>
            <path d="M36.5 33.5c-9.1 0-16.5 7.4-16.5 16.5s7.4 16.5 16.5 16.5c4.5 0 8.5-1.8 11.5-4.7l-4.2-4.2c-1.9 1.9-4.5 3-7.3 3-5.7 0-10.3-4.6-10.3-10.3s4.6-10.3 10.3-10.3c2.8 0 5.4 1.1 7.3 3l4.2-4.2c-3-2.9-7-4.3-11.5-4.3zm27 0c-9.1 0-16.5 7.4-16.5 16.5s7.4 16.5 16.5 16.5c4.5 0 8.5-1.8 11.5-4.7l-4.2-4.2c-1.9 1.9-4.5 3-7.3 3-5.7 0-10.3-4.6-10.3-10.3s4.6-10.3 10.3-10.3c2.8 0 5.4 1.1 7.3 3l4.2-4.2c-3-2.9-7-4.3-11.5-4.3z" fill="currentColor"/>
          </svg>
          CREATIVE COMMONS BY 4.0. MMXXVI.
        </p>
      </footer>
    </div>

    <!-- The one bit of client-side JS: tick the ticker clock every second.
         `is:inline` tells Astro to ship this as-is rather than bundling it. -->
    <script is:inline>
      (function () {
        const MONTHS = ['JANUARY', 'FEBRUARY', 'MARCH', 'APRIL', 'MAY', 'JUNE', 'JULY', 'AUGUST', 'SEPTEMBER', 'OCTOBER', 'NOVEMBER', 'DECEMBER'];
        const pad = (n) => String(n).padStart(2, '0');
        // Both ticker copies share these classes, so update them together.
        const dateEls = document.querySelectorAll('.ticker-date');
        const timeEls = document.querySelectorAll('.ticker-time');
        function tick() {
          const d = new Date();
          const dateStr = `${MONTHS[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;
          const timeStr = `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
          dateEls.forEach((el) => { el.textContent = dateStr; });
          timeEls.forEach((el) => { el.textContent = timeStr; });
        }
        tick();
        setInterval(tick, 1000);
      })();
    </script>
  </body>
</html>

<style>
  /* Styles in an Astro <style> block are automatically scoped to THIS
     component — they won't leak into pages or other components. */

  /* The column caps width at 600px and centers it. No horizontal padding:
     the colored bars are full-bleed (edge-to-edge of the column on desktop,
     edge-to-edge of the screen on mobile), exactly as the design intends.
     Elements that hold text — the ticker and footer — add their own inset. */
  .column {
    width: 100%;
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .ticker {
    font-size: var(--size-footer);
    padding: var(--space-1) 0;
    overflow: hidden;
    white-space: nowrap;
  }
  /* The track holds two identical groups side by side and slides left by one
     group's width (50% of the track), then repeats — a seamless marquee. */
  .ticker__track {
    display: inline-flex;
    animation: ticker-scroll 40s linear infinite;
  }
  .ticker__group {
    flex: none;
    padding-right: var(--space-2);
  }
  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  /* Respect users who prefer reduced motion: hold the ticker still. */
  @media (prefers-reduced-motion: reduce) {
    .ticker__track { animation: none; }
  }

  /* The site URL in the ticker is a link home — looks like the surrounding
     text, underlines on hover/focus. */
  .ticker__link {
    color: inherit;
    text-decoration: none;
  }
  .ticker__link:hover,
  .ticker__link:focus-visible {
    text-decoration: underline;
  }

  .masthead {
    background: var(--mo-cyan);
    color: var(--black);
    font-size: var(--size-heading);
    text-align: center;
    height: var(--bar-section);
    line-height: var(--bar-section); /* vertically center the single line */
  }

  /* Breadcrumb links in the masthead — look like the surrounding text,
     underline on hover/focus to signal they're clickable. */
  .masthead__link {
    color: inherit;
    text-decoration: none;
  }
  .masthead__link:hover,
  .masthead__link:focus-visible {
    text-decoration: underline;
  }

  .pinwheel {
    display: block;
    width: 40px;
    margin: 0 auto 12px;
    animation: spin 15.625s linear infinite;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pinwheel { animation: none; }
  }

  .site-footer {
    font-size: var(--size-footer);
    text-align: center;
    padding: var(--space-4) var(--space-2);
    line-height: var(--leading-display);
    margin-top: 64px;
  }
  .site-footer__link {
    color: inherit;
    text-decoration: none;
  }
  .site-footer__link:hover,
  .site-footer__link:focus-visible {
    text-decoration: underline;
  }

  .site-footer__cc {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }
</style>
