---
/*
  DIY Guide — landing page (/diy).

  Sections, top to bottom (ticker, masthead, footer come from BaseLayout):
    1. Hero            — the M ❀ logo
    2. Letter          — "Dear future organizers" backstory
    3. The basics      — the 6-week program
    4. Ring ring       — join the next Q&A (info session signup)
    5. How to…         — links to the four ordered subpages

  The RSVP link is a placeholder (href="#") until the info-session signup URL
  is shared.
*/
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import GuideLink from '../../components/GuideLink.astro';
import ProgramStep from '../../components/ProgramStep.astro';
import AudioPlayer from '../../components/AudioPlayer.astro';

// The four subpages, read in order. Each links to the next at its own foot.
const guideLinks = [
  { number: '01', label: 'Gather participants', href: '/diy/gather-participants' },
  { number: '02', label: 'Get dumbphones',      href: '/diy/get-dumbphones' },
  { number: '03', label: 'Facilitate meetups',  href: '/diy/facilitate-meetups' },
  { number: '04', label: 'Host an exhibition',  href: '/diy/host-an-exhibition' },
];

// The 6-week program shown under "The basics".
// Each question underlines a key phrase (the <u> tags are rendered as HTML in
// ProgramStep via set:html — see that component).
const program = [
  { number: 1, color: 'yellow', title: 'Communication', question: 'how do devices shape our patterns of communication? ppl <u>sign the Offline Pledge</u> and ceremonially flip off their smartphones.' },
  { number: 2, color: 'cyan',   title: 'Memory',        question: "what do we notice when we're not feeling distracted? ppl interview each other about <u>a creative outlet</u> they're exploring." },
  { number: 3, color: 'pink',   title: 'Navigation',    question: "how do we experience urban space when we're off the GPS? ppl <u>use paper maps</u> to share the story of their commute." },
  { number: 4, color: 'blue',   title: 'Boredom',       question: 'how do we inhabit the vacancies in our attention? ppl <u>split into 2 teams</u> for a collage competition and plan a midweek outing.' },
  { number: 5, color: 'red',    title: 'Graduation',    question: 'what are we going to carry with us from this experience together? ppl give <u>mini-commencement speeches</u> with their takeaways.' },
  { number: 6, color: 'black',  title: 'Exhibition',    question: 'how did we make the most of our offtime? ppl share their <u>creative outlets</u> at a public party for the community.' },
];
---

<BaseLayout title="DIY Guide — Month Offline" masthead="Month Offline > DIY Guide">
  <div class="sections">
    <!-- 1. Hero -->
    <Hero />

    <!-- 2. Letter -->
    <section class="card">
      <h3 class="letter__salutation font-display">Dear organizers,</h3>
      <p class="body">
        we're glad you're curious about starting a Month Offline cohort in ur
        city. a little backstory: MO's founding flipmates first met at a
        phone-free Shabbat dinner in <a href="https://www.ustreetcommunity.org/temperance-alley-garden" target="_blank" rel="noopener">Temperance Alley</a>
        -- a community garden and outdoor classroom in Washington, DC. Grant and
        Danny teamed up with Aaron and Josh to design a challenge that would help
        neighbors liberate their attention and deepen their sense of place. all
        of us had been practicing our own forms of <a href="https://www.schoolofattention.org/attention-activism" target="_blank" rel="noopener">attention activism</a>
        ... building clay ovens, inspiring friends to use flip phones, organizing
        local field trips.
      </p>
      <p class="body">
        in April 2025, we came together to post flyers around DC with a simple
        invitation: CALL 1-844-OFFLINE if u want to ditch ur smartphone for 30
        days and experience the beauty of Life beyond the screen with a small
        group of peers. to our surprise, ppl started leaving us heartfelt
        voicemails about why they wanted to flip off. we put together a MO field
        kit with old-school tools that would help us fill the void left behind
        by our smartphones. and a few weeks later, 15 strangers assembled at a
        local bar to embark on what turned out to be a transformative trip.
      </p>

      <div class="letter__audio">
        <AudioPlayer
          title="1-844-Offline Voice Collage"
          byline="May 2025 * edited by Josh Morin"
          src="/audio/1844OFFLINE.mp3"
        />
      </div>

      <p class="body">
        if that was THE END, it would have been enough! but we were so energized
        by what emerged in newfound offtime that we decided to organize another
        cohort. and another. and another ... after crushing the July '25
        challenge, Lydia came on board as MO's first-ever trained facilitator
        and not long after, she helped bring the challenge to a whole new city:
        the Big Apple.
      </p>
      <p class="body">
        so much has bloomed now: new friendships, photo books, dance videos,
        plays, short films, a makeshift telegraph, subjective cartographies,
        kombucha, repaired jeans, a petition to save the local park -- more than
        we can remember. inspired by all we've witnessed, we created this DIY
        guide to encourage u to start a MO cohort (and to make it ur own)! inside
        you'll find helpful hints and printable materials for every stage of ur
        organizing. u got this! don't hesitate to reach out.
      </p>
      <p class="body letter__signoff">
        Less is MO,<br />
        Aaron, Josh, &amp; Lydia<br />
        <a href="mailto:month@offline.community">month@offline.community</a>
      </p>
      <img
        class="letter__image"
        src="/images/mo_bike.jpg"
        width="1512"
        height="1134"
        alt="Rows of open yellow Month Offline field-kit boxes, each with a 'Welcome to the Flip Side' letter printed inside the lid"
      />
    </section>

    <!-- 3. The basics -->
    <SectionHeader label="The basics" color="yellow" />
    <section class="card">
      <p class="body">
        <u>weekly meetups are at the heart of MO</u>. the most important
        'content' of the curriculum is the stories that participants bring back
        from the field. it's not a retreat, but a <em>reentry</em> program to
        the beauty of local Life beyond the screen. dumbco can help u get
        hooked up with phones, but remember ... the device is just a gateway.
      </p>
      <p class="body">
        the og challenge is built around 5 themes and a community exhibition,
        but u r welcome to remix our recipe to better suit the needs of ur
        neighborhood:
      </p>
      <div class="program">
        {program.map((step) => (
          <ProgramStep number={step.number} color={step.color} title={step.title} question={step.question} />
        ))}
      </div>
    </section>

    <!-- 4. Ring ring — interest form -->
    <SectionHeader label="Ring ring: let's get organized" color="yellow" />
    <section class="lydia">
      <div class="lydia__top">
        <p class="body">
          ready to take the next step? start thinking about a co-facilitator, a venue, and ur first meetup date. submit an interest form and we'll invite u to the next Q&amp;A session where u can ask any questions, meet other aspiring organizers, and learn how to get dumbphones.
        </p>
        <img class="lydia__photo" src="/images/lydia.jpg" width="1200" height="1200" alt="Lydia, a Month Offline organizer" />
      </div>
      <a class="lydia__btn font-display" href="https://tally.so/r/RGgD2p">COUNT ME IN</a>
    </section>

    <!-- 5. How to… -->
    <SectionHeader label="How to..." color="yellow" />
    {guideLinks.map((link) => (
      <GuideLink number={link.number} label={link.label} href={link.href} />
    ))}
  </div>
</BaseLayout>

<style>
  /* Standard body paragraph (Syne Mono). Spacing between stacked paragraphs. */
  .body {
    font-size: var(--size-body);
    line-height: var(--leading-body);
  }
  .body + .body {
    margin-top: var(--space-3);
  }

  /* Letter salutation + sign-off. */
  .letter__salutation {
    font-size: var(--size-body);
    margin-bottom: var(--space-3);
  }
  .letter__signoff {
    margin-top: var(--space-3);
  }

  /* The field-kit photo that closes the letter. */
  .letter__image {
    width: 100%;
    height: auto;
    margin-top: var(--space-3);
  }

  /* Vertical breathing room around the audio player in the letter. */
  .letter__audio {
    margin: var(--space-3) 0;
  }

  /* The 5-week program list inside the "How it works" card. */
  .program {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-3);
  }

  /* Lydia intro-call card (pink, black text). */
  .lydia {
    background: var(--mo-pink);
    color: var(--black);
    padding: var(--space-2);
  }
  .lydia__top {
    display: flex;
    gap: var(--space-2);
    align-items: flex-start;
  }
  .lydia__photo {
    flex: none;
    width: 110px;
    height: 110px;
    object-fit: cover;
  }
  .lydia__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: var(--space-3);
    padding: var(--space-2);
    background: var(--black);
    color: var(--white);
    text-decoration: none;
    font-size: var(--size-body);
    transition: background-color 0.15s ease;
  }
  /* Hover: lighten the box 20% toward white. */
  .lydia__btn:hover {
    background: color-mix(in srgb, var(--black) 80%, white);
  }
</style>
