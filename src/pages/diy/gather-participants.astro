---
/*
  DIY subpage 1 of 4 — How to Gather Participants (/diy/gather-participants).

  Sections, top to bottom (ticker, masthead, footer come from BaseLayout):
    1. Hero       — the M ❀ logo
    2. Heading    — cyan "* HOW TO GATHER PARTICIPANTS" bar
    3. Body       — the how-to copy, with a flyering photo mid-card
    4. Resources  — pink download cards (PDFs hosted on the site)
    5. Next       — link forward to the next subpage in the read-in-order set

  Underlined words in the body use plain <u> for emphasis (same as the home
  page's "offline.community"/"dumb.co") — they're not links.
---------------------------------------------------------------------------*/
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import NextLink from '../../components/NextLink.astro';

// Resource cards. Hosted PDFs live in /public/resources/; the sign-up form is
// an external Tally link. Each card opens its resource in a new tab.
const resources = [
  {
    title: 'Month Offline Flyers',
    description: 'editable posters that u can post around your neighborhood! include ur phone number or e-mail address in the blank space at the bottom.',
    href: '/resources/mo_flyers.pdf',
  },
  {
    title: 'sign up form',
    description: 'duplicate the interest form we created to keep track of all your participants.',
    href: 'https://tally.so/r/KYOAOA',
  },
  {
    title: 'Month Offline Postcards',
    description: 'encouraging letters from past participants. cut them out and mail them as a welcome gift.',
    href: '/resources/mo_postcards.pdf',
  },
];
---

<BaseLayout title="How to Gather Participants — Month Offline" masthead="Month Offline > DIY Guide > Participants">
  <div class="sections">
    <!-- 1. Hero -->
    <Hero />

    <!-- 2. Heading -->
    <SectionHeader label="How to gather participants" color="cyan" />

    <!-- 3. Body -->
    <section class="card">
      <h3 class="label">How do I get the word out?</h3>
      <p class="body">
        it's much easier to flip off in community than on ur own. the first step
        is to <u>find at least one other person who wants to help u bring this
        to life</u>.
      </p>
      <p class="body">
        work together to <u>recruit a group of 10–30 participants</u> to go offline
        together. set up a phone number, email address, or form where ppl can
        sign up. invite some friends to join you, and ask them to invite some of
        their friends.
      </p>
      <p class="body">
        flyer on utility boxes, in cafes, book shops, bars -- or wherever u can
        find a community bulletin board. table on a busy street corner. submit
        an invitation to local newsletters or e-mail listservs. try to <u>avoid
        using social media</u> ... u will be surprised by how many ppl come
        out of the woodwork! the medium is the message.
      </p>

      <img
        class="card__photo"
        src="/images/mo_flyer.png"
        width="1500"
        height="1000"
        alt="A hand wheat-pasting a Month Offline poster onto a city wall"
      />

      <p class="body">
        <u>cold call</u> ppl as they sign up. ask them about why they decided to
        take the plunge, their hopes &amp; dreams for the month. make sure
        they're free on the date &amp; time you've selected. share a bit about
        urself and what to expect from the meetups.
      </p>
      <p class="body">
        <u>send a reminder</u> 1 week before and 1 day before with all ur deets:
        date, time, &amp; location. try including a playful instruction like
        "look 4 the man in the sunglasses and give him the secret passcode LESS
        IS MO."
      </p>

      <h3 class="label">Where should we meet up?</h3>
      <p class="body">
        <u>choose a day and time</u> that u and ur fellow organizers are
        available for 5 consecutive weeks. meetups typically last 1.5-2hours,
        and remember u will need at least a half hour on either end for set up
        and takedown!
      </p>
      <p class="body">
        <u>find a local venue</u> that will host u, and get to know the owners.
        Month Offline is a great way to patronize local businesses and support
        IRL community hubs. private rooms or relatively quite spaces at
        restaurants &amp; bars tend to work best, but some groups meet outside
        at the park.
      </p>
      <p class="body">
        once you've found ur ppl and place, ur ready to start prepping for the
        meetups!
      </p>

      <img
        class="card__photo"
        src="/images/participants_02.png"
        width="1512"
        height="1134"
        alt="Month Offline participants gathered around a table at their meetup venue"
      />
    </section>

    <!-- 4. Resources -->
    <SectionHeader label="Resources" />
    {resources.map((r) => (
      <ResourceCard title={r.title} description={r.description} href={r.href} />
    ))}

    <!-- 5. Next — read-in-order, per CLAUDE.md (Gather → Get Dumbphones → …). -->
    <NextLink label="How to Get Dumbphones" href="/diy/get-dumbphones" />
  </div>
</BaseLayout>

<style>
  /* Standard body paragraph (Syne Mono). Spacing between stacked paragraphs. */
  .body {
    font-size: var(--size-body);
    line-height: var(--leading-body);
  }
  .body + .body {
    margin-top: var(--space-3);
  }

  /* The flyering photo sits between paragraphs inside the white card. */
  .card__photo {
    width: 100%;
    height: auto;
    margin: var(--space-3) 0;
  }
</style>
