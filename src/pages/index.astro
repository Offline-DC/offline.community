---
/*
  Home page.

  Sections, top to bottom (the ticker, masthead, and footer live in
  BaseLayout and wrap every page):
    1. Hero        — the M ❀ logo in a bordered yellow block
    2. Intro       — what Month Offline is
    3. Press       — "Read all about it" coverage
    4. How it works— meetups, the dumbphone, and the directory blurb
    5. Locations   — the cohort directory (placeholder rows for now)
    6. CTA         — start a cohort in your city → DIY guide
    7. Photos      — a strip of three images
*/
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CohortRow from '../components/CohortRow.astro';
import PressItem from '../components/PressItem.astro';
import { getCohorts } from '../lib/cohorts.js';

// Pull the cohort directory from the published Google Sheet at build time.
// Empty until cohorts are added to the sheet — the section shows an
// empty-state message below in that case.
const cohorts = await getCohorts();
---

<BaseLayout title="Month Offline">
  <div class="sections">
    <!-- 1. Hero -->
    <Hero />

    <!-- 2. Intro -->
    <section class="card">
      <p class="lead__tagline font-display">part support group, part happy hour, part classroom</p>
      <p class="lead__headline font-display">try a dumbphone for 30 days and join a cohort of neighbors for weekly meetups and mutual encouragement.</p>
      <p class="lead__coda font-display">if not now, when?</p>
      <p class="body">
        ahoy! <u>you've reached offline.community</u> — a directory of Month
        Offline cohorts and a guide to starting ur own. the very first MO
        challenge took place in Washington DC in May 2025. since then, over 400
        brave souls have entered the flip side with their neighbors — turning
        doomscroll into neighborhood stroll, plugging their creativity into the
        local landscape, &amp; filling the smartphone-shaped hole in their lives
        with on-land joy. check the directory below to see if there's already a
        MO cohort in ur city. if not, might u be the one to get it going? ⁕
      </p>
    </section>

    <!-- 3. Press -->
    <SectionHeader label="Read all about it" color="cyan" />
    <section class="card card--gray">
      <ul class="press-list">
        <PressItem
          headline="A group of us ditched our smartphones for a month. It changed us."
          outlet="Washington Post"
          href="https://www.washingtonpost.com/dc-md-va/interactive/2025/smartphones-dumbphones-month-offline/"
        />
        <PressItem
          headline="The flip-phone cleanse"
          outlet="The Atlantic"
          href="https://www.theatlantic.com/technology/2026/04/month-offline-smartphone-detox/686911/"
        />
        <PressItem
          headline="Would you try the 30-day flip phone challenge?"
          outlet="Dazed"
          href="https://www.dazeddigital.com/life-culture/article/69882/1/month-offline-smartphone-support-group-unplugging-flip-offline-detox"
        />
      </ul>
    </section>

    <!-- 4. How it works -->
    <SectionHeader label="How it works" color="cyan" />
    <section class="card">
      <p class="body">
        <u>flipping off is better together!</u> the MO challenge is a community
        of practice for groups of 10–30. participants gather at a local venue,
        sign a pledge to forgo the use of their smartphone for 30 days, and
        support the vitality of the neighborhood through their presence +
        patronage.
      </p>

      <h3 class="label">Facilitated IRL meetups</h3>
      <ul class="bullets">
        <li>✺ <u>hands-on activities</u> to explore weekly themes on the frictions &amp; fruits of offline living</li>
        <li>✺ <u>dedicated time</u> to incubate your creative outlet and encourage others' exploration</li>
        <li>✺ <u>graduation ceremony</u> to celebrate each other's offtime</li>
      </ul>

      <h3 class="label">dumbphone 2 from <a href="https://dumb.co" target="_blank" rel="noopener">dumb.co</a></h3>
      <ul class="bullets">
        <li>☎ <u>classic flip phone</u> designed with Month Offline participants in mind</li>
        <li>☎ <u>unlimited</u> calling &amp; texting, grainy 2MP camera, the sweet sound of closure when u snap it shut</li>
        <li>☎ <u>option to sync</u> calls, texts, &amp; contacts with ur "smart" phone</li>
      </ul>

      <h3 class="label">community exhibition</h3>
      <ul class="bullets">
        <li>❉ <u>public party</u> with the friends &amp; family of MO participants</li>
        <li>❉ <u>showcase</u> stories, artworks, and practices that emerged during the month</li>
      </ul>
    </section>

    <!-- 5. Locations -->
    <SectionHeader label="Month Offline locations" color="cyan" />
    <!-- Directory blurb sits beneath the locations header in its own blue box. -->
    <section class="directory-note">
      <p>
        each cohort is unique, but we're united by the MO pledge and our
        commitment to attention liberation. join an existing cohort or start
        ur own.
      </p>
    </section>
    {cohorts.length > 0
      ? cohorts.map((c) => (
          <CohortRow location={c.location} date={c.date} organizer={c.organizer} href={c.href} />
        ))
      : <p class="no-cohorts">No cohorts listed yet — be the first to start one in your city, below.</p>
    }

    <!-- 6. CTA → DIY guide -->
    <a class="cta" href="/diy">
      <div class="cta__head">
        <span class="font-display">Start Month Offline in ur city</span>
        <span class="font-display">&gt;&gt;&gt;</span>
      </div>
      <p class="cta__blurb">
        not seeing ur location? don't fret ... use the DIY guide to roll ur own cohort.
      </p>
    </a>

    <!-- 7. Photos -->
    <section class="photos">
      <img src="/images/photo-1.png" alt="Participants at a Month Offline meetup" />
      <img src="/images/photo-2.png" alt="A Month Offline gathering" />
      <img src="/images/photo-3.png" alt="A Month Offline exhibition" />
    </section>
  </div>
</BaseLayout>

<style>
  /* `.sections` (the section stack) and `.card` now live in global.css,
     shared across pages. */

  /* Locations empty-state (shown on the black page, white text). */
  .no-cohorts {
    font-size: var(--size-body);
    padding: var(--space-3) var(--space-2);
  }

  .lead__tagline {
    font-size: 15px;
    line-height: var(--leading-display);
    text-align: center;
    white-space: nowrap;
  }
  .lead__headline {
    font-size: 24px;
    line-height: var(--leading-display);
    text-align: center;
    margin-top: var(--space-2);
  }
  .lead__coda {
    font-size: var(--size-body);
    line-height: var(--leading-display);
    text-align: center;
    margin-top: var(--space-4);
  }

  /* Standard body paragraph (Syne Mono). Home-page copy reads a touch larger
     than the 16px site default. */
  .body {
    font-size: 18px;
    line-height: var(--leading-body);
  }
  .body + .body,
  .bullets + .body {
    margin-top: var(--space-3);
  }
  .lead__coda + .body {
    margin-top: var(--space-3);
  }

  /* Directory blurb box beneath the "Month Offline locations" header. */
  .directory-note {
    background: var(--mo-yellow);
    color: var(--black);
    padding: var(--space-3);
    font-size: var(--size-body);
    line-height: var(--leading-body);
  }

  .bullets {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
  }
  .bullets li + li {
    margin-top: var(--space-2);
  }

  /* Press list: headlines separated by thin black rules. */
  .press-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .press-list :global(.press-item) {
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--black);
  }
  .press-list :global(.press-item:first-child) {
    padding-top: 0;
  }
  .press-list :global(.press-item:last-child) {
    border-bottom: none;
    padding-bottom: 0;
  }

  /* CTA bar (pink). */
  .cta {
    display: block;
    background: var(--mo-pink);
    color: var(--black);
    text-decoration: none;
    padding: var(--space-2);
    min-height: var(--bar-cta);
    transition: background-color 0.15s ease;
  }
  /* Hover: lighten the box 20% toward white. */
  .cta:hover {
    background: color-mix(in srgb, var(--mo-pink) 80%, white);
  }
  .cta__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-2);
    font-size: var(--size-body);
  }
  .cta__head .font-display:last-child {
    transition: transform 0.15s ease;
  }
  .cta:hover .cta__head .font-display:last-child {
    transform: translateX(2px);
  }
  .cta__blurb {
    font-size: var(--size-body);
    margin-top: var(--space-1);
  }

  /* Photo strip: three equal images in a row. */
  .photos {
    display: flex;
    gap: var(--space-1);
  }
  .photos img {
    flex: 1;
    width: 0; /* let flex-basis drive width so all three are equal */
    height: 219px;
    object-fit: cover;
  }
</style>
