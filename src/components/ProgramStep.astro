---
/*
  ProgramStep.astro — one week of the 5-week program in "How it works":
  a colored square with the step number, then a title and its guiding question.
*/
interface Props {
  number: number;
  color: 'yellow' | 'cyan' | 'pink' | 'blue' | 'red' | 'black';
  title: string;
  question: string;
}
const { number, color, title, question } = Astro.props;
const numStyle = color === 'black'
  ? 'background: var(--black); color: var(--white);'
  : `background: var(--mo-${color});`;
---

<div class="program-step">
  <div class="program-step__num font-display" style={numStyle}>{number}</div>
  <div class="program-step__text">
    <h4 class="program-step__title font-display">{title}</h4>
    <!-- set:html renders the <u> underline tags inside the question. The copy
         is our own (not user input), so this is safe. -->
    <p class="program-step__question" set:html={question}></p>
  </div>
</div>

<style>
  .program-step {
    display: flex;
    gap: var(--space-2);
    /* stretch so the colored number box grows to match the text height */
    align-items: stretch;
  }

  .program-step__num {
    flex: none;
    width: 48px;
    /* No fixed height: the box stretches to the full row (text) height. The
       number stays anchored near the top — align-items: flex-start pins it up,
       and line-height: 48px centers it within the top 48px, exactly where it
       sat when the box was a 48px square. */
    display: flex;
    align-items: flex-start;
    justify-content: center;
    color: var(--black);
    font-size: var(--size-heading);
    line-height: 48px;
  }

  .program-step__title {
    font-size: var(--size-body);
  }

  .program-step__question {
    font-size: var(--size-body);
    margin-top: var(--space-1);
  }
</style>
