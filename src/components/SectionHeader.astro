---
/*
  SectionHeader.astro — the "* HEADING" bar that introduces each section.
  Pass the label; the leading asterisk and uppercasing are handled here.

  `color` picks the bar color: yellow (default) or cyan.
*/
interface Props {
  label: string;
  color?: 'cyan' | 'yellow' | 'pink';
}
const { label, color = 'yellow' } = Astro.props;
---

<h2 class="section-header" style={`background: var(--mo-${color});`}>* {label}</h2>

<style>
  .section-header {
    color: var(--black);
    font-size: var(--size-heading);
    line-height: var(--leading-display);
    /* Flex centering + min-height keeps single-line bars at the design's 48px
       while letting a two-line header (e.g. the Lydia call-out) grow. */
    display: flex;
    align-items: center;
    min-height: var(--bar-section);
    padding: var(--space-1) var(--space-2);
  }
</style>
