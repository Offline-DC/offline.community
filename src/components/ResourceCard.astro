---
/*
  ResourceCard.astro — a pink resource row in a DIY subpage's "Resources"
  section, e.g. "MONTH OFFLINE FLYERS  ↗" with a short description beneath.

  The whole pink box is one link. `href` points at the resource — usually a
  PDF we host under /resources/, sometimes an external page (e.g. a sign-up
  form). Opening in a new tab (target="_blank") keeps the guide page open
  behind it; rel="noopener" is the standard safety attribute for that.
*/
interface Props {
  title: string;
  description: string;
  href: string;
}
const { title, description, href } = Astro.props;
---

<a class="resource" href={href} target="_blank" rel="noopener">
  <div class="resource__head">
    <span class="resource__title font-display">{title}</span>
    <!-- Open-in-new-tab icon (arrow leaving a box). `currentColor` keeps it
         black, matching the text; aria-hidden since the link text says it all. -->
    <svg class="resource__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M14 4h6v6" />
      <path d="M20 4l-9 9" />
      <path d="M19 13v6a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h6" />
    </svg>
  </div>
  <p class="resource__desc">{description}</p>
</a>

<style>
  .resource {
    display: block;
    background: var(--mo-pink);
    color: var(--black);
    text-decoration: none;
    padding: var(--space-2);
    transition: background-color 0.15s ease;
  }
  /* Hover: lighten the box 20% toward white. */
  .resource:hover {
    background: color-mix(in srgb, var(--mo-pink) 80%, white);
  }
  .resource__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-2);
  }
  .resource__title {
    font-size: var(--size-body);
  }
  .resource__icon {
    flex: none;
    width: 20px;
    height: 20px;
  }
  .resource__desc {
    font-size: var(--size-body);
    margin-top: var(--space-1);
  }
</style>
